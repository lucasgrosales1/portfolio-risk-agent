# Copy this file to .env and fill in your key.
#   cp .env.example .env
#
# .env is gitignored. This file is not — it exists so anyone cloning the repo
# knows what configuration is expected without ever seeing a real key.

# Optional. Without it, reports render with rule-based commentary instead of
# AI-written commentary. Every number in the report is computed in Python
# either way — the key only affects the prose.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Models used by the two agents. Defaults are set in src/pra/config.py;
# override here only if you want to experiment.
# PRA_NARRATIVE_MODEL=claude-sonnet-5
# PRA_COMPLIANCE_MODEL=claude-haiku-4-5

# Risk-free rate used in the Sharpe ratio, as a decimal (0.042 = 4.2%).
# Leave unset to pull the live 13-week Treasury bill yield.
# PRA_RISK_FREE_RATE=
